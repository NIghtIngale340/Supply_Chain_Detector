OPENAI_API_KEY=
PYPI_BASE_URL=https://pypi.org/pypi
NPM_BASE_URL=https://registry.npmjs.org
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql://postgres:postgres@db:5432/scd
# LLM_PROVIDER: stub (safe default, no API key needed), nvidia, openai, ollama, disabled
LLM_PROVIDER=stub
LLM_TRIGGER_THRESHOLD=20
CACHE_TTL_SECONDS=1800
RESULT_TTL_SECONDS=86400
OPENAI_MODEL=gpt-4o-mini
# --- NVIDIA NIM (set LLM_PROVIDER=nvidia and provide real key) ---
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_MAX_OUTPUT_TOKENS=600
# --- Ollama (local fallback, set LLM_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=huihui_ai/qwen2.5-coder-abliterate:7b
OLLAMA_MAX_OUTPUT_TOKENS=600
# --- Database ---
POSTGRES_DB=scd
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# --- Observability ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# --- UI ---
SCD_API_BASE_URL=http://localhost:8000
